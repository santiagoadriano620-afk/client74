Module
  name: game_hotkeys
  description: Manage client hotkeys
  author: andrefaramir, BeniS
  website: https://github.com/edubart/otclient
  sandboxed: true
  scripts: [ hotkeys_manager ]
  autoload: true
  autoload-priority: 1000
  dependencies: [ client_topmenu, game_interface ]
  @onLoad: init()
  @onUnload: terminate()
